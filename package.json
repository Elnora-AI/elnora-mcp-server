{
  "name": "@elnora-ai/mcp-server",
  "version": "0.9.0",
  "mcpName": "io.github.Elnora-AI/elnora-mcp-server",
  "description": "MCP server for Elnora Platform — AI-powered bioprotocol optimization",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "node --input-type=commonjs -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Elnora-AI/elnora-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/Elnora-AI/elnora-mcp-server/issues"
  },
  "homepage": "https://elnora.ai",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "elnora",
    "bioprotocol",
    "ai-agent",
    "lab-protocol"
  ],
  "files": [
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "axios": "^1.8.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.0",
    "ioredis": "^5.10.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
